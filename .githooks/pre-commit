#!/usr/bin/env sh
set -eu

STAGED="$(git diff --cached --name-only)"
[ -z "$STAGED" ] && exit 0

needs_chrono=0
for f in $STAGED; do
  case "$f" in
    *.py|*.js|*.ts|*.tsx|*.go|*.java|*.rb|*.php|*.sh|Dockerfile|Makefile)
      needs_chrono=1
      ;;
  esac
done

if [ "$needs_chrono" -eq 1 ]; then
  echo "$STAGED" | grep -qx 'docs/PROJECT_CHRONOLOGY.md' || {
    echo "ERROR: code changes detected but docs/PROJECT_CHRONOLOGY.md is not staged."
    echo "Please update project chronology before commit."
    exit 1
  }
fi

# Block accidental secrets in tracked files
if echo "$STAGED" | grep -E '(^|/)\.env($|\.)' | grep -Evq '(^|/)\.env\.example$'; then
  echo "ERROR: .env file appears in staged changes. Remove secrets from commit."
  exit 1
fi

if echo "$STAGED" | grep -Eq '(^|/)(id_rsa|id_ed25519|.*\.(pem|key|p12|pfx|crt|cer|mobileprovision))$'; then
  echo "ERROR: secret or key material appears in staged files."
  exit 1
fi

SCAN_DIFF="$(git diff --cached --no-ext-diff --binary -- . ':(exclude).githooks/pre-commit' ':(exclude).githooks/pre-push' ':(exclude).env.example' || true)"
if echo "$SCAN_DIFF" | grep -Eiq '(sk-proj-[A-Za-z0-9_-]{20,}|sk-[A-Za-z0-9_-]{20,}|OPENAI_API_KEY=[^[:space:]]*(sk-proj-|sk-[A-Za-z0-9_-]{20,})|DOLPHIN_SESSION_TOKEN=[^[:space:]]{8,}|DOLPHIN_CLOUD_API_KEY=[^[:space:]]{8,}|-----BEGIN (RSA|OPENSSH|EC|DSA|PRIVATE KEY)-----)'; then
  echo "ERROR: staged diff appears to contain secrets or private key material."
  exit 1
fi

exit 0
